<%- include('partials/header') %>

<main class="section container">
  <% const wishlistCount = wishlistItems.length; %>
  <div class="wishlist-page">
    <section class="wishlist-hero">
      <div>
        <p class="eyebrow">Your saved picks</p>
        <h1>Wishlist</h1>
        <p>Curated essentials you’ve saved for later. Move them to your cart whenever you’re ready.</p>
      </div>
      <div class="wishlist-actions">
        <% if (wishlistCount > 0) { %>
          <form method="POST" action="/wishlist/add-all-to-cart" class="inline-form">
            <button class="btn btn-primary" type="submit">Add all to cart</button>
          </form>
        <% } %>
      </div>
    </section>

    <div class="wishlist-grid">
      <div class="wishlist-items">
        <div class="wishlist-summary">
          <strong><%= wishlistCount %> item<%= wishlistCount === 1 ? '' : 's' %> saved</strong>
        </div>

        <% if (wishlistCount === 0) { %>
          <div class="empty-state">
            <h3>Your wishlist is empty</h3>
            <p>Save products you love and revisit them whenever you want.</p>
            <a class="btn btn-primary" href="/">Browse products</a>
          </div>
        <% } else { %>
          <% wishlistItems.forEach((item) => { %>
            <article class="wishlist-item">
              <img src="<%= item.image %>" alt="<%= item.name %>" />
              <div class="wishlist-item-body">
                <div class="wishlist-item-top">
                  <div>
                    <h3><%= item.name %></h3>
                    <p><%= item.description %></p>
                  </div>
                  <span class="badge"><%= item.category %></span>
                </div>
                <div class="wishlist-item-meta">
                  <span>Organic favorite</span>
                  <strong>₹<%= item.price %></strong>
                </div>
                <div class="wishlist-item-actions">
                  <form method="POST" action="/wishlist/move-to-cart" class="inline-form">
                    <input type="hidden" name="productId" value="<%= item.id %>" />
                    <button class="btn btn-primary" type="submit">Move to cart</button>
                  </form>
                  <form method="POST" action="/wishlist/remove" class="inline-form">
                    <input type="hidden" name="productId" value="<%= item.id %>" />
                    <button class="btn product-wishlist-btn" type="submit">Remove</button>
                  </form>
                </div>
              </div>
            </article>
          <% }) %>
        <% } %>
      </div>

      <aside class="wishlist-sidebar">
        <div class="summary-card">
          <h2>Why use your wishlist?</h2>
          <ul class="feature-list">
            <li>Save your favorite wellness essentials in one place.</li>
            <li>Keep track of products you want to compare or buy later.</li>
            <li>Move items into your cart instantly when you are ready.</li>
          </ul>
          <a class="btn btn-secondary" href="/">Continue shopping</a>
        </div>
      </aside>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
