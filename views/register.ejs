<%- include('partials/header') %>

<main class="section container">
  <div class="login-shell">
    <div class="login-card">
      <p class="eyebrow">Join Us</p>
      <h1>Create Your Account</h1>
      <p class="login-copy">Get started with Vithi Organics and enjoy organic wellness delivered to you.</p>

      <% if (typeof error !== 'undefined' && error) { %>
        <p style="color:#b42318; font-weight:600;"><%= error %></p>
      <% } %>

      <form class="auth-form" method="POST" action="/register">
        <label for="fullname">Full Name</label>
        <input id="fullname" name="fullname" type="text" placeholder="John Doe" required />

        <label for="email">Email Address</label>
        <input id="email" name="email" type="email" placeholder="you@example.com" required />

        <label for="phone">Phone Number</label>
        <input id="phone" name="phone" type="tel" placeholder="+91 98765 43210" />

        <label for="password">Password</label>
        <input id="password" name="password" type="password" placeholder="Create a strong password" required />

        <button type="submit" class="btn btn-primary auth-btn">Create Account</button>
      </form>

      <p class="switch-auth">Already have an account? <a href="/login">Sign in</a></p>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
