<%- include('partials/header') %>

<main class="section container">
  <div class="cart-page">
    <h1 style="margin-bottom: 1.2rem;">Shopping Cart</h1>
    <div class="cart-layout">
      <div class="cart-items">
        <div class="cart-header">
          <p style="color: var(--muted); font-size: 0.95rem;">3 items in cart</p>
        </div>

        <div class="cart-item">
          <img src="https://images.unsplash.com/photo-1506126613408-eca07ce68773?auto=format&fit=crop&w=200&q=80" alt="Organic Turmeric Powder" />
          <div class="item-details">
            <h3>Organic Turmeric Powder</h3>
            <p style="color: var(--muted); font-size: 0.9rem;">200g | ₹249</p>
          </div>
          <div class="item-qty">
            <button class="qty-btn">−</button>
            <input type="number" value="2" readonly />
            <button class="qty-btn">+</button>
          </div>
          <strong>₹498</strong>
          <button class="remove-btn">✕</button>
        </div>
      </div>

      <aside class="cart-summary">
        <div class="summary-card">
          <h2>Order Summary</h2>
          <div class="summary-row"><span>Subtotal</span><strong>₹1,496</strong></div>
          <div class="summary-row"><span>Shipping</span><strong>Free</strong></div>
          <div class="summary-row"><span>Tax</span><strong>₹180</strong></div>
          <div class="summary-divider"></div>
          <div class="summary-row" style="font-size: 1.1rem;"><strong>Total</strong><strong style="color: var(--green-900);">₹1,676</strong></div>
          <form method="POST" action="/orders">
            <input type="hidden" name="productName" value="Organic Turmeric Powder" />
            <input type="hidden" name="total" value="1676" />
            <button class="btn btn-primary" style="width: 100%; margin-top: 1.2rem;">Proceed to Payment</button>
          </form>
          <a href="/" class="btn btn-secondary" style="width: 100%; display: block; text-align: center; margin-top: 0.6rem;">Continue Shopping</a>
        </div>
      </aside>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
