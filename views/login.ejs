<%- include('partials/header') %>

<main class="section container">
  <div class="login-shell">
    <div class="login-card">
      <p class="eyebrow">Welcome Back</p>
      <h1>Sign in to Vithi Organics</h1>
      <p class="login-copy">Access your orders, wishlist, and trusted organic essentials in seconds.</p>

      <% if (typeof error !== 'undefined' && error) { %>
        <p style="color:#b42318; font-weight:600;"><%= error %></p>
      <% } %>

      <form class="auth-form" method="POST" action="/login">
        <label for="email">Email Address</label>
        <input id="email" name="email" type="email" placeholder="you@example.com" required />

        <label for="password">Password</label>
        <input id="password" name="password" type="password" placeholder="Enter your password" required />

        <button type="submit" class="btn btn-primary auth-btn">Login</button>
      </form>

      <p class="switch-auth">New to Vithi Organics? <a href="/register">Create account</a></p>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
