<%- include('layout', { body: `
<section class="hero">
  <div class="hero-slider" aria-label="Featured banners">
    <article class="slide active">
      <div class="overlay"></div>
      <div class="container slide-content">
        <p class="eyebrow">Certified Organic Essentials</p>
        <h1>Pure by Nature, Better for You</h1>
        <p>Discover holistic wellness with herbs, oils, grains, and family-friendly nutrition.</p>
        <div class="hero-actions">
          <a class="btn btn-primary" href="#best-sellers">Shop Now</a>
          <a class="btn btn-secondary" href="#categories">Explore Categories</a>
        </div>
      </div>
    </article>
  </div>
</section>

<section class="section container" id="categories">
  <div class="section-heading">
    <p class="eyebrow">Shop by Category</p>
    <h2>Carefully Curated Organic Essentials</h2>
  </div>
  <div class="card-grid categories-grid">
    <article class="card category-card">
      <img src="https://images.unsplash.com/photo-1467453678174-768ec283a940?auto=format&fit=crop&w=900&q=80" alt="Fresh organic produce" />
      <div class="card-body">
        <h3>Organic Fruits & Vegetables</h3>
        <p>Seasonal farm-fresh picks grown with natural methods and full traceability.</p>
        <span>120+ products</span>
      </div>
    </article>
    <article class="card category-card">
      <img src="https://images.unsplash.com/photo-1509440159596-0249088772ff?auto=format&fit=crop&w=900&q=80" alt="Herbal wellness products" />
      <div class="card-body">
        <h3>Ayurvedic Herbs</h3>
        <p>Powerful herbs and natural remedies aligned with traditional wellness principles.</p>
        <span>85+ products</span>
      </div>
    </article>
    <article class="card category-card">
      <img src="https://images.unsplash.com/photo-1471864190281-a93a3070b6de?auto=format&fit=crop&w=900&q=80" alt="Organic pantry staples" />
      <div class="card-body">
        <h3>Pantry Essentials</h3>
        <p>Staples like grains, oils, pulses, and spices that bring wholesome flavor home.</p>
        <span>200+ products</span>
      </div>
    </article>
  </div>
</section>

<section class="section container" id="best-sellers">
  <div class="section-heading flex-between">
    <div>
      <p class="eyebrow">Best Selling Products</p>
      <h2>Customer Favorites</h2>
    </div>
  </div>
  <div class="card-grid product-grid">
    <% products.forEach((product) => { %>
      <article class="card product-card">
        <a class="product-link" href="/products/<%= product.id %>"><img src="<%= product.image %>" alt="<%= product.name %>" /></a>
        <div class="card-body">
          <h3><a href="/products/<%= product.id %>"><%= product.name %></a></h3>
          <p><%= product.description %></p>
          <div class="price-row">
            <strong>₹<%= product.price %></strong>
            <div class="actions">
              <form method="POST" action="/cart/add">
                <input type="hidden" name="productId" value="<%= product.id %>" />
                <button class="btn btn-primary" type="submit">Add to Cart</button>
              </form>
              <form method="POST" action="/wishlist/add">
                <input type="hidden" name="productId" value="<%= product.id %>" />
                <button class="btn product-wishlist-btn wishlist-icon-btn" type="submit" aria-label="Add <%= product.name %> to wishlist">♥</button>
              </form>
            </div>
          </div>
        </div>
      </article>
    <% }) %>
  </div>
</section>
` }) %>
